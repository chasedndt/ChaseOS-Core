# ChaseOS Local Credential Template
# ---------------------------------
# Copy this file to .env and fill in real values for this ChaseOS install.
# .env is gitignored and must never be committed or pasted into chat/logs.
# The ChaseOS CLI loads root .env into process env vars at startup.
# Windows/User environment variables still work and take precedence.
#
# Rule: tracked files store credential names and placeholders only.
# Real secret values belong in .env, an OS env var, or a secret manager.

# --- AI / Research APIs ---
OPENAI_API_KEY=<paste-your-openai-api-key-here>
# Required for: OpenAI provider-backed Chat/Studio proof and OpenAI SIC embeddings.
# Current MVP setup metadata should reference this name only: OPENAI_API_KEY.

PERPLEXITY_API_KEY=<paste-your-perplexity-api-key-here>
# Required for: Perplexity live research capture connector.

ANTHROPIC_API_KEY=<paste-your-anthropic-api-key-here>
# Required for: Hermes / Claude-backed synthesis lanes when selected.

XAI_API_KEY=<paste-your-xai-api-key-here>
# Optional: Grok/xAI capture connector.

# --- Google / Drive / Docs / Gmail ---
GOOGLE_API_KEY=<paste-your-google-api-key-here>
# Optional: public Google Drive API listing.

GOOGLE_OAUTH_TOKEN=<paste-your-google-oauth-token-here>
# Short-lived OAuth token for private Google resources; not preferred for automation.

GOOGLE_SERVICE_ACCOUNT_FILE=.chaseos/credentials/google-service-account.json
# Recommended for automated Google Drive/Docs access.
# Store the JSON file under .chaseos/credentials/ or another ignored local path.

GMAIL_IMAP_USER=you@example.com
GMAIL_APP_PASSWORD=<paste-your-gmail-app-password-here>
# Optional: email acquisition adapter. Use app passwords, not account passwords.

# --- Delivery ---
# Discord server/user/bot/channel IDs do not belong here. Put those in the
# machine-local `.chaseos/discord_instance_bindings.yaml`, copied from
# `runtime/bindings/discord_instance_bindings.example.yaml`.
DISCORD_WEBHOOK_URL=<paste-your-discord-webhook-url-here>
# Used by: scheduled briefing pipelines (SBP) with Discord delivery. Per-pipeline
# webhook overrides are read from each pipeline's configured env var.
# Fallback Discord webhook if a pipeline-specific webhook is not set.

WHOP_API_KEY=<paste-your-whop-api-key-here>
# Required only when Whop delivery adapter is active and approved.

# --- n8n ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=<paste-your-n8n-api-key-here>
N8N_MCP_ACCESS_TOKEN=<paste-your-n8n-mcp-access-token-here>

# --- Messaging / operator surfaces ---
TELEGRAM_BOT_TOKEN=<paste-your-telegram-bot-token-here>
TELEGRAM_CHAT_ID=<paste-your-telegram-chat-id-here>
SLACK_BOT_TOKEN=<paste-your-slack-bot-token-here>
SLACK_APP_TOKEN=<paste-your-slack-app-token-here>
SLACK_SIGNING_SECRET=<paste-your-slack-signing-secret-here>

# --- Future high-risk surfaces ---
# Do not add wallet seed phrases, exchange secrets, brokerage credentials, or
# host admin credentials for MVP. Use separate governed setup once a real scope
# and approval chain exists.
