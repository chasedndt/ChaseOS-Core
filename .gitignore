# ============================================================
# ChaseOS .gitignore
# ============================================================
# Tracks: vault markdown, runtime code, policy, manifests, templates.
# Never tracks: credentials, env files, local state, large artifacts,
#               Python cache, venv, Obsidian app config, SQLite dbs.
# ============================================================

# --- Credentials and secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/

# --- Python runtime ---
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg

# --- Test and temp artifacts ---
.pytest_cache/
.pytest-tmp/
.pytest_tmp/
.pytest_tmp_env/
.codex/
.codex-*/
.codex_tmp/
.codex_tmp_test/
.tmp/
*.tmp

# --- Obsidian app config (not content) ---
.obsidian/

# --- ChaseOS runtime state (local machine state, not code) ---
.chaseos/
# Includes machine-local Discord bindings such as
# .chaseos/discord_instance_bindings.yaml.
# .chaseos/ contains: dedup_registry.json, watch_folders.json,
# watch_processed.json, config.yaml — all local machine state,
# not portable or meaningful in version control.

# --- SQLite databases (agent bus, artifact store) ---
*.db
*.db-wal
*.db-shm
*.sqlite
runtime/agent_bus/*.db*
runtime/acquisition/artifact_store.db*

# --- Large runtime artifacts (generated, not source) ---
runtime/acquisition/packs/
runtime/scaffold/generated/
07_LOGS/Operator-Screenshots/

# --- Studio shell state ---
runtime/studio/approvals/
runtime/studio/shell/frontend/assets/cytoscape.min.js

# --- Native Runtime Chat event bridge — operational state + secrets (never commit) ---
# native-state holds the SQLite event store, JSONL event stores, per-adapter
# cursors, health snapshots, emitter sequence state, approval/audit records,
# and — critically — the local HMAC signing keys. All generated local state.
runtime/studio/chat/native-state/
# Belt-and-suspenders for the signing keys even if native-state/ is ever un-ignored.
runtime/studio/chat/native-state/runtime-event-keys/
# Append-only runtime event spool + dead-letter queue (operational, can grow).
07_LOGS/Runtime-Events/
# Security self-detection telemetry: gate-denial log + behavior-tripwire reports
# (machine-local operational state, like Runtime-Events above).
07_LOGS/Runtime-Audits/
# SQLite WAL/shm sidecars for the chat event store (extends *.sqlite above).
*.sqlite-wal
*.sqlite-shm

# --- Runtime lifecycle and process state ---
runtime/lifecycle/run/
runtime/lifecycle/bootstrap/
runtime/osril/run/
runtime/events/

# --- Hermes and OpenClaw local state ---
.hermes/
.openclaw/

# --- Claude Code local session state (NOT the hooks/settings.json — those are tracked) ---
.claude/settings.local.json
.claude/hooks/__pycache__/

# --- VS Code workspace settings (keep .vscode/extensions.json if desired) ---
.vscode/settings.json
.vscode/launch.json

# --- macOS artifacts (if ever synced) ---
.DS_Store
Thumbs.db

# --- Review-tool / agent worktree snapshots (local-only; contain SQLite DBs,
#     event spools, and per-pass state — must never be committed) ---
.gr/
NUL
CORE_EXPORT_STATUS.json
