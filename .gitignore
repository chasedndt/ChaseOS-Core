# ===== Build / tooling =====
__pycache__/
*.py[cod]
.venv/
.venv-*/
*.egg-info/
dist/
build/
.pytest_cache/
.pytest_tmp*/
*.db
*.db-wal
*.db-shm
.DS_Store

# ===== Secrets / credentials (never commit) =====
.env
.env.*
!.env.example
*.key
*.pem
credentials*.json

# ===== YOUR PERSONAL INSTANCE — never commit your private vault data =====
# ChaseOS Core ships *templates and synthetic examples* (tracked below via the
# `!` negations). When you run your own instance you create real notes, projects,
# logs, identity, and runtime state in these folders — those stay PRIVATE on your
# machine and must never be committed to a Core fork.
# See docs/getting-started/Core-vs-Personal.md.

# Identity (only the template ships)
/SOUL.md

# Home — keep README + *.example.md, ignore your real notes
/00_HOME/*
!/00_HOME/README.md
!/00_HOME/*.example.md

# Projects — keep README + the synthetic example only
/01_PROJECTS/*
!/01_PROJECTS/README.md
!/01_PROJECTS/Example-Project-OS.md

# Knowledge — keep README + *.example.md
/02_KNOWLEDGE/*
!/02_KNOWLEDGE/README.md
!/02_KNOWLEDGE/*.example.md

# Inputs — keep README only (raw/untrusted captures stay local)
/03_INPUTS/*
!/03_INPUTS/README.md

# Logs — keep the folder READMEs + example indexes, ignore real logs
/07_LOGS/**
!/07_LOGS/**/
!/07_LOGS/README.md
!/07_LOGS/**/*.example.md

# Archive — keep README + example index
/99_ARCHIVE/*
!/99_ARCHIVE/README.md
!/99_ARCHIVE/Documentation-History/
!/99_ARCHIVE/Documentation-History/*.example.md

# Runtime / instance state, memory, and local config (never published)
/.chaseos/
/.hermes/
/.obsidian/
runtime/memory/nav/
runtime/lifecycle/run/
runtime/lifecycle/state/
runtime/agent_bus/*.db

# Runtime memory is per-instance state — Core ships the memory code + schemas +
# READMEs only, never populated per-runtime profiles/ledgers/scorecards/repair.
runtime/memory/adapters/**/*.json
!runtime/memory/adapters/_identity_ledger_schema.json
runtime/memory/scorecards/*.json
runtime/memory/repair/*.json
!runtime/memory/repair/_schema.json

# Instance execution artifacts + populated workspaces are per-instance state, not Core.
runtime/adapters/*/runs/
runtime/source_intelligence/workspaces/*/
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite3
