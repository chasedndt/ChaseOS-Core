{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseos/runtime/adapters/codex/codex-result.schema.json",
  "title": "ChaseOS Codex Bus Adapter Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "task_id", "run_id", "from", "event_type", "message", "artifacts", "created_at"],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "from": {"const": "Codex"},
    "event_type": {"type": "string", "enum": ["proposal", "patch", "risk", "blocked", "complete"]},
    "message": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "path", "description"],
        "properties": {
          "artifact_type": {"type": "string", "enum": ["diff", "markdown", "json", "log"]},
          "path": {"type": "string", "minLength": 1},
          "description": {"type": "string"}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
