{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseos/runtime/agent_bus/task-packet.schema.json",
  "title": "ChaseOS Runtime Coordination Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "from",
    "to",
    "intent",
    "status",
    "request",
    "expected_output",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "reply_to": {"type": ["string", "null"]},
    "from": {"type": "string", "minLength": 1},
    "to": {"type": "string", "minLength": 1},
    "intent": {
      "type": "string",
      "enum": ["TASK", "RESULT", "BLOCKER", "REVIEW", "QUESTION", "NOTICE"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "claimed", "in_progress", "blocked", "review", "done", "cancelled", "expired"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"],
      "default": "normal"
    },
    "owner": {"type": ["string", "null"]},
    "owner_instance": {"type": ["string", "null"]},
    "request": {"type": "string", "minLength": 1},
    "expected_output": {"type": "string", "minLength": 1},
    "depends_on": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "source_platform": {"type": ["string", "null"]},
    "source_channel_id": {"type": ["string", "null"]},
    "source_thread_id": {"type": ["string", "null"]},
    "source_channel_class": {"type": ["string", "null"]},
    "conversation_key": {"type": ["string", "null"]},
    "origin_message_id": {"type": ["string", "null"]},
    "control_plane_route": {"type": ["string", "null"]},
    "work_fingerprint": {"type": ["string", "null"]},
    "execution_constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_shell_commands": {"type": "boolean"},
        "allow_live_subprocess": {"type": "boolean"},
        "allowed_write_paths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "write_policy": {
          "type": "string",
          "enum": ["adapter-default", "declared-paths", "none"]
        }
      },
      "default": {}
    },
    "notes": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
